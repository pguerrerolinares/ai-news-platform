# =============================================================================
# AI News Platform — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# --- Database ---
POSTGRES_DB=ainews
POSTGRES_USER=ainews
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://ainews:change-me@localhost:5432/ainews
DATABASE_URL_SYNC=postgresql://ainews:change-me@localhost:5432/ainews

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
DEBUG=false
CORS_ORIGINS=http://localhost:4200

# --- Auth ---
JWT_SECRET=generate-a-random-secret-here
SHARED_PASSWORD=change-me

# --- LLM (Kimi/Moonshot, OpenAI-compatible) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL=kimi-latest

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ALERTS_ENABLED=true

# --- Sources ---
ENABLED_SOURCES=hackernews,arxiv,reddit,rss,github,huggingface
MAX_ITEMS_PER_SOURCE=50

# HackerNews
HN_MIN_POINTS=10
HN_SINCE_HOURS=24
HN_SEARCH_QUERIES=AI,LLM,GPT,machine learning,neural network,deep learning

# arXiv
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.LG
ARXIV_KEYWORDS=LLM,transformer,language model,GPT,BERT,attention mechanism,fine-tuning,RLHF,RAG,retrieval,agent,multi-modal,diffusion,neural,deep learning,reinforcement learning

# Reddit
REDDIT_SUBREDDITS=MachineLearning,LocalLLaMA,artificial
REDDIT_TOP_LIMIT=25

# RSS
RSS_FEEDS=https://openai.com/blog/rss.xml,https://blog.google/technology/ai/rss/,https://huggingface.co/blog/feed.xml

# GitHub
GITHUB_TOKEN=
GITHUB_SEARCH_QUERIES=AI,LLM,machine-learning,generative-AI
GITHUB_MIN_STARS=50

# HuggingFace
HF_MIN_DOWNLOADS=100

# --- Topics & Filtering ---
TOPICS=modelos,herramientas,papers,productos,open_source,agentes,regulacion
MIN_RELEVANCE_SCORE=0.8

# --- Validation ---
ENABLE_NEWS_VALIDATION=true
TRUSTED_NEWS_DOMAINS=openai.com,anthropic.com,deepmind.google,ai.meta.com,huggingface.co,arxiv.org,github.com,techcrunch.com,theverge.com,wired.com,arstechnica.com,reuters.com

# --- Pipeline ---
PIPELINE_SCHEDULE_HOUR=8
PIPELINE_SCHEDULE_MINUTE=0

# --- Observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Embeddings (OpenAI-compatible, for RAG chat) ---
EMBEDDING_API_KEY=sk-your-openai-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# --- Backups (optional) ---
# B2_BUCKET=your-backblaze-bucket
