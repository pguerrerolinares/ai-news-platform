{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "mock": "ng serve --configuration mock",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "e2e": "playwright test",
    "e2e:report": "playwright show-report playwright-report"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/animations": "^21.1.4",
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.1.5",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "dompurify": "^3.3.1",
    "highcharts": "^12.5.0",
    "highcharts-angular": "^5.4.0",
    "marked": "^17.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@playwright/test": "^1.58.2",
    "@types/dompurify": "^3.0.5",
    "typescript": "~5.9.2"
  }
}
